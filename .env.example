ANTHROPIC_API_KEY=

# Clerk — sign up at clerk.com, create an application, and copy these from
# its API Keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Apple WeatherKit — Apple Developer Program membership required.
# Register a Services ID with WeatherKit enabled, then create a WeatherKit
# key in the Apple Developer portal and download its .p8 private key.
APPLE_WEATHERKIT_TEAM_ID=
APPLE_WEATHERKIT_SERVICE_ID=
APPLE_WEATHERKIT_KEY_ID=
# Paste the .p8 contents; keep the \n line breaks escaped on one line.
APPLE_WEATHERKIT_PRIVATE_KEY=

# Postgres — any provider works; Neon (neon.tech) has a free tier that needs
# no server management.
DATABASE_URL=

# Web Push VAPID keys — generate your own, no external account needed:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret the scheduler sends as "Authorization: Bearer <value>" when
# it hits /api/cron/check-alerts. Vercel Cron does this automatically once
# this env var is set — any random string works.
CRON_SECRET=
